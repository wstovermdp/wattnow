# Local: mqtt://localhost:1883 (no auth needed for local Mosquitto)
# Prod (Railway): mqtts://<your-cluster>.hivemq.cloud:8883
MQTT_BROKER_URL=mqtt://localhost:1883

# MQTT credentials. Required for HiveMQ Cloud, optional for local Mosquitto.
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic to subscribe to. Use a wildcard (+/#) to catch multiple device IDs.
# Local default matches the fake publisher: solarmary/telemetry
MQTT_TOPIC=solarmary/telemetry

# Supabase project credentials.
# Local should point at your dev project; Railway points at prod.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_TABLE=telemetry
