{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo \"No build step required — tsx runs TypeScript directly at runtime.\""
  },
  "deploy": {
    "startCommand": "npm start --workspace=bridge",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
